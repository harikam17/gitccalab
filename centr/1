FIBONACCI 
#include <stdio.h>
int main() {
    int n, i;
    int a = 0, b = 1, next;
    printf("Enter number of terms: ");
    scanf("%d", &n);
    printf("Fibonacci Series:\n");
    for(i = 1; i <= n; i++) {
        printf("%d ", a);
        next = a + b;
        a = b;
        b = next;
    }
    return 0;
}

SWAP TWO NUMBERS 
#include <stdio.h>
int main() {
    int a = 5, b = 10, temp;
    temp = a;
    a = b;
    b = temp;
    printf("After swapping:\n");
    printf("a = %d, b = %d", a, b);
    return 0;
}

